<Window x:Class="FleetManagement.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FleetManagement.WPF"
        xmlns:views="clr-namespace:FleetManagement.WPF.Views"
        mc:Ignorable="d"
        Title="Sistem za upravljanje voznim parkom" Height="550" Width="950" WindowStartupLocation="CenterScreen">
    <Grid>
        <TabControl>
            <TabItem Header="Vozila" FontSize="14" Padding="15,5">
                <views:VehiclesView x:Name="VehiclesControl"/>
            </TabItem>

            <TabItem Header="Vozači" FontSize="14" Padding="15,5">
                <views:DriversView x:Name="DriversControl"/>
            </TabItem>

            <TabItem Header="Vožnje" FontSize="14" Padding="15,5">
                <views:TripsView x:Name="TripsControl"/>
            </TabItem>

            <TabItem Header="Obaveštenja" FontSize="14" Padding="15,5">
                <views:NotificationsView x:Name="NotificationsControl"/>
            </TabItem>

            <TabItem Header="Održavanje" FontSize="14" Padding="15,5">
                <views:MaintenanceView x:Name="MaintenanceControl"/>
            </TabItem>
        </TabControl>

    </Grid>
</Window>
