<UserControl x:Class="FleetManagement.WPF.Views.TripsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FleetManagement.WPF.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="850">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Leva strana: Pokretanje vožnje -->
        <Border BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="5" Padding="15" Margin="0,0,10,0" Background="#F9F9F9">
            <StackPanel>
                <TextBlock Text="Pokretanje nove vožnje" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>

                <TextBlock Text="Izaberi slobodno vozilo:" Margin="0,5,0,2"/>
                <ComboBox ItemsSource="{Binding AvailableVehicles}" SelectedItem="{Binding SelectedVehicle}" Height="25" VerticalContentAlignment="Center">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Make}" FontWeight="Bold"/>
                                <TextBlock Text=" "/>
                                <TextBlock Text="{Binding Model}"/>
                                <TextBlock Text=" ("/>
                                <TextBlock Text="{Binding PlateNumber}"/>
                                <TextBlock Text=")"/>
                            </StackPanel>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <TextBlock Text="Izaberi slobodnog vozača:" Margin="0,10,0,2"/>
                <ComboBox ItemsSource="{Binding AvailableDrivers}" SelectedItem="{Binding _SelectedDriver}" Height="25" VerticalContentAlignment="Center">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding FirstName}"/>
                                <TextBlock Text=" "/>
                                <TextBlock Text="{Binding LastName}"/>
                                <TextBlock Text=" ("/>
                                <TextBlock Text="{Binding LicenseNumber}"/>
                                <TextBlock Text=")"/>
                            </StackPanel>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <TextBlock Text="Početna lokacija:" Margin="0,10,0,2"/>
                <TextBox Text="{Binding StartLocation, UpdateSourceTrigger=PropertyChanged}" Height="25" VerticalContentAlignment="Center"/>

                <TextBlock Text="Krajnja lokacija (planirana):" Margin="0,10,0,2"/>
                <TextBox Text="{Binding EndLocation, UpdateSourceTrigger=PropertyChanged}" Height="25" VerticalContentAlignment="Center"/>

                <Button Content="Pokreni Vožnju" Command="{Binding StartTripCommand}" 
                        Height="35" Margin="0,20,0,0" Background="#007ACC" Foreground="White" FontWeight="Bold">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="3"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="Evidencija svih vožnji u sistemu" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>
                <DataGrid Grid.Row="1" ItemsSource="{Binding TripsList}" SelectedItem="{Binding SelectedTrip}" AutoGenerateColumns="False" 
                          IsReadOnly="True" GridLinesVisibility="Horizontal" BorderThickness="1" BorderBrush="#CCCCCC" Background="White">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Vozilo" Binding="{Binding VehicleDetails}" Width="1.5*"/>
                        <DataGridTextColumn Header="Vozač" Binding="{Binding DriverName}" Width="*"/>
                        <DataGridTextColumn Header="Ruta" Binding="{Binding StartLocation}" Width="100"/>
                        <DataGridTextColumn Header="Do" Binding="{Binding EndLocation}" Width="100"/>
                        <DataGridTextColumn Header="Početna km" Binding="{Binding StartMileage}" Width="80"/>
                        <DataGridTextColumn Header="Krajnja km" Binding="{Binding EndMileage}" Width="80"/>
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="80"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <Border Grid.Row="1" BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="5" Padding="15" Background="#FFF9E6">
                <StackPanel>
                    <TextBlock Text="Završetak izabrane aktivne vožnje" FontSize="16" FontWeight="Bold" Foreground="#856404" Margin="0,0,0,10"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <TextBlock Text="Izabrana vožnja:" FontSize="11" Foreground="#555555"/>
                            <TextBlock Text="{Binding SelectedTrip.VehicleDetails, FallbackValue='Izaberite aktivnu vožnju iz tabele iznad...'}" FontSize="13" FontWeight="Bold" Margin="0,3,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="0,0,10,0">
                            <TextBlock Text="Krajnja kilometraža:" FontSize="11" Foreground="#555555"/>
                            <TextBox Text="{Binding EndMileage, UpdateSourceTrigger=PropertyChanged}" Height="25" VerticalContentAlignment="Center" Margin="0,3,0,0"/>
                        </StackPanel>

                        <Button Grid.Column="2" Content="Završi Vožnju" Command="{Binding CompleteTripCommand}" 
                                Width="120" Height="30" VerticalAlignment="Bottom" Background="#FFC107" Foreground="#333333" FontWeight="Bold">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="3"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
